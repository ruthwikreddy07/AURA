{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo/config-plugins": "^55.0.9",
    "@expo/metro-runtime": "~55.0.6",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.5.2",
    "@react-navigation/bottom-tabs": "^7.15.6",
    "@react-navigation/native": "^7.1.34",
    "@react-navigation/native-stack": "^7.14.6",
    "buffer": "^6.0.3",
    "expo": "~55.0.8",
    "expo-av": "^16.0.8",
    "expo-camera": "~55.0.11",
    "expo-crypto": "~55.0.10",
    "expo-dev-client": "^55.0.34",
    "expo-local-authentication": "~55.0.9",
    "expo-localization": "^55.0.14",
    "expo-notifications": "~0.29.0",
    "expo-secure-store": "~55.0.9",
    "expo-status-bar": "~55.0.4",
    "node-forge": "^1.4.0",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-ble-peripheral-manager": "^0.3.0",
    "react-native-ble-plx": "^3.5.1",
    "react-native-hce": "^0.3.0",
    "react-native-nfc-manager": "^3.17.2",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "15.15.3",
    "react-native-web": "^0.21.0"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.5.0",
    "babel-jest": "^29.7.0",
    "jest": "^29.7.0",
    "jest-expo": "~55.0.0",
    "patch-package": "^8.0.1"
  },
  "jest": {
    "preset": "jest-expo",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ],
    "setupFilesAfterFramework": [
      "@testing-library/jest-native/extend-expect"
    ]
  },
  "private": true
}
